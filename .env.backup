# Configuration pour Docker Compose
# Modifiez cette IP avec l'adresse IP de votre machine pour permettre l'accès réseau
# Pour trouver votre IP :
# - Windows : cmd > ipconfig
# - Mac/Linux : terminal > ifconfig ou ip addr

# IMPORTANT : Remplacez cette IP par la vôtre !
HOST_IP=192.168.1.96

# URLs du backend et frontend
API_URL=http://192.168.1.96:5001
FRONTEND_URL=http://192.168.1.96:3000

# OnlyOffice
ONLYOFFICE_PUBLIC_URL=http://192.168.1.96:8080

# Ports
BACKEND_PORT=5001
FRONTEND_PORT=3000
POSTGRES_PORT=5432

# Configuration PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=supfile

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-12345
JWT_EXPIRES_IN=7d

# OAuth2 (Optionnel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OpenRouter AI - Bobby le robot
# Obtiens ta clé sur : https://openrouter.ai/keys
