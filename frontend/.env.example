# Configuration de l'URL de l'API Backend

# Pour localhost uniquement :
# VITE_API_URL=http://localhost:5001

# Pour accès réseau local, remplacez par l'IP de votre serveur :
# VITE_API_URL=http://192.168.1.100:5001

VITE_API_URL=http://localhost:5001

# ========================================
# INSTRUCTIONS POUR L'ACCÈS RÉSEAU LOCAL
# ========================================
#
# 1. Trouvez l'adresse IP de la machine qui héberge le backend :
#    - Windows : ouvrez cmd et tapez "ipconfig"
#    - Mac/Linux : ouvrez terminal et tapez "ifconfig" ou "ip addr"
#    Cherchez l'adresse IPv4 (ex: 192.168.1.100)
#
# 2. Mettez à jour VITE_API_URL :
#    VITE_API_URL=http://VOTRE_IP:5001
#
# 3. Les autres PC du réseau pourront accéder à l'application via :
#    http://VOTRE_IP:3000
