# Configuration de la base de données
# Utiliser l'utilisateur applicatif dédié (pas le superuser postgres)
# En local sans Docker : remplacer supfile_app par vos identifiants locaux
DATABASE_URL=postgresql://supfile_app:CHANGEZ_MOI@localhost:5432/supfile

# Configuration JWT
JWT_SECRET=
JWT_MFA_SECRET=
JWT_EXPIRES_IN=7d

# Configuration API
# Pour localhost uniquement :
# API_URL=http://localhost:5001
# Pour accès réseau local, remplacez par l'IP de votre machine :
# API_URL=http://192.168.1.100:5001
API_URL=http://localhost:5001

# Configuration Frontend
# Pour localhost uniquement :
# FRONTEND_URL=http://localhost:3000
# Pour accès réseau local, utilisez une liste séparée par des virgules :
# FRONTEND_URL=http://localhost:3000,http://192.168.1.100:3000,http://192.168.1.101:3000
FRONTEND_URL=http://localhost:3000

PORT=5001

# Répertoire de téléversement
UPLOAD_DIR=./uploads

# OAuth2 - Google (Optionnel - Laissez vide si non utilisé)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 - GitHub (Optionnel - Laissez vide si non utilisé)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Environnement Node
NODE_ENV=development
MFA_ENCRYPTION_KEY=
# Clé obligatoire pour chiffrer les secrets MFA (32 bytes hex = 64 caractères)
# Générer avec : openssl rand -hex 32
DEK_WRAP_SECRET=
FILE_ENCRYPTION_KEY=
ONLYOFFICE_JWT_SECRET=
# Générer JWT_SECRET, JWT_MFA_SECRET, DEK_WRAP_SECRET, FILE_ENCRYPTION_KEY et ONLYOFFICE_JWT_SECRET avec : openssl rand -base64 48

# SMTP Configuration (Emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@supfile.com
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_MOCK=false
MAIL_LOGO_URL=

# Object Storage — MinIO S3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=supfile-uploads
S3_ACCESS_KEY_ID=supfile_app_user
S3_SECRET_ACCESS_KEY=CHANGEZ_MOI_mot_de_passe_app

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# Web Push VAPID (générer avec: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ========================================
# INSTRUCTIONS POUR L'ACCÈS RÉSEAU LOCAL
# ========================================
#
# 1. Trouvez l'adresse IP de votre machine :
#    - Windows : ouvrez cmd et tapez "ipconfig"
#    - Mac/Linux : ouvrez terminal et tapez "ifconfig" ou "ip addr"
#    Cherchez l'adresse IPv4 (ex: 192.168.1.100)
#
# 2. Mettez à jour les variables :
#    API_URL=http://VOTRE_IP:5001
#    FRONTEND_URL=http://localhost:3000,http://VOTRE_IP:3000
#
# 3. Assurez-vous que le pare-feu autorise les connexions sur les ports 3000 et 5001
#
# 4. Les autres PC du réseau pourront accéder à l'application via :
#    http://VOTRE_IP:3000
