# Configuration de la base de données
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/supfile

# Configuration JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-12345
JWT_EXPIRES_IN=7d

# Configuration API
# Pour localhost uniquement :
# API_URL=http://localhost:5001
# Pour accès réseau local, remplacez par l'IP de votre machine :
# API_URL=http://192.168.1.100:5001
API_URL=http://localhost:5001

# Configuration Frontend
# Pour localhost uniquement :
# FRONTEND_URL=http://localhost:3000
# Pour accès réseau local, utilisez une liste séparée par des virgules :
# FRONTEND_URL=http://localhost:3000,http://192.168.1.100:3000,http://192.168.1.101:3000
FRONTEND_URL=http://localhost:3000

PORT=5001

# Répertoire de téléversement
UPLOAD_DIR=./uploads

# OAuth2 - Google (Optionnel - Laissez vide si non utilisé)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 - GitHub (Optionnel - Laissez vide si non utilisé)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Environnement Node
NODE_ENV=development

# SMTP Configuration (Emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@supfile.com

# ========================================
# INSTRUCTIONS POUR L'ACCÈS RÉSEAU LOCAL
# ========================================
#
# 1. Trouvez l'adresse IP de votre machine :
#    - Windows : ouvrez cmd et tapez "ipconfig"
#    - Mac/Linux : ouvrez terminal et tapez "ifconfig" ou "ip addr"
#    Cherchez l'adresse IPv4 (ex: 192.168.1.100)
#
# 2. Mettez à jour les variables :
#    API_URL=http://VOTRE_IP:5001
#    FRONTEND_URL=http://localhost:3000,http://VOTRE_IP:3000
#
# 3. Assurez-vous que le pare-feu autorise les connexions sur les ports 3000 et 5001
#
# 4. Les autres PC du réseau pourront accéder à l'application via :
#    http://VOTRE_IP:3000
