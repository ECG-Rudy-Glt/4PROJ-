generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------
// 1. UTILISATEURS & SÉCURITÉ
// --------------------------------------


enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

enum Role {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DelegationStatus {
  ACTIVE
  REVOKED
}

enum OrganizationMemberRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?   // Null si OAuth
  firstName     String?
  lastName      String?
  avatar        String?
  role          Role      @default(USER)
  accountStatus AccountStatus @default(ACTIVE)

  provider      String?   @default("local")
  providerId    String?

  // Quotas & UI
  quotaUsed     BigInt    @default(0)
  quotaLimit    BigInt    @default(32212254720) // 30 GB
  theme         String    @default("light")
  language      String    @default("fr")

  // Plans & Billing
  plan          Plan      @default(FREE)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  stripeCustomerId String?

  // Coffre-fort sécurisé
  vaultEnabled      Boolean   @default(false)
  vaultPasswordHash String?
  vaultUnlockUntil  DateTime?
  vaultLockedUntil  DateTime?
  vaultFailedAttempts Int     @default(0)
  vaultLastUnlockedAt DateTime?

  // MFA (Multi-Factor Authentication)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?   // Secret TOTP encrypté
  mfaBackupCodes String[] // Array de codes de récupération hashés
  mfaSetupAt    DateTime? // Date de configuration du MFA
  
  // Chiffrement par utilisateur (KEK/DEK)
  kekSalt       String?   // Sel PBKDF2 (hex, 16 bytes) pour dériver la KEK depuis le mot de passe
  encryptedDek  String?   // DEK chiffrée avec KEK (hex : IV+ciphertext+AuthTag)

  // Sécurité & Sessions
  tokenVersion  Int       @default(1) // Pour l'invalidation globale des tokens
  lastActiveAt  DateTime  @default(now()) // Pour le timeout d'inactivité

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  files         File[]
  folders       Folder[]
  sharedLinks   SharedLink[]
  trustedDevices TrustedDevice[]
  organizationMemberships OrganizationMember[]
  currentOrganizationId String?
  currentOrganization   Organization? @relation("CurrentOrganization", fields: [currentOrganizationId], references: [id], onDelete: SetNull)

  // Gestion des partages reçus/envoyés
  sharedWithMe  SharedFolder[] @relation("SharedWithUser")
  sharedByMe    SharedFolder[] @relation("SharedByUser")

  filesSharedWithMe SharedFile[] @relation("FileSharedWithUser")
  filesSharedByMe   SharedFile[] @relation("FileSharedByUser")

  // Nouvelles fonctionnalités
  refreshTokens RefreshToken[] // Pour la sécurité JWT
  passwordResetTokens PasswordResetToken[]
  auditLogs     AuditLog[]     // Pour le Dashboard (Activité)
  tags          Tag[]          // Tags créés par l'utilisateur
  comments      Comment[]      // Commentaires créés par l'utilisateur
  fileVersions  FileVersion[]  // Versions de fichiers créées
  switchLinksAsRoot   AccountSwitchLink[] @relation("SwitchRootUser")
  switchLinksAsTarget AccountSwitchLink[] @relation("SwitchTargetUser")
  delegationsGiven    Delegation[] @relation("DelegationOwner")
  delegationsReceived Delegation[] @relation("DelegationDelegate")
  notifications      Notification[]      // Notifications de l'utilisateur
  pushSubscriptions  PushSubscription[]  // Abonnements push navigateur
  conversations      Conversation[]      // Historique des conversations Bobby

  @@index([email])
  @@index([providerId])
  @@index([currentOrganizationId])
}

// Nouveau : Pour gérer la déconnexion et la sécurité
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// Nouveau : Pour la réinitialisation de mot de passe
model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// --------------------------------------
// 2. DOSSIERS
// --------------------------------------

model Folder {
  id        String   @id @default(uuid())
  name      String
  path      String   // Breadcrumbs

  parentId  String?
  parent    Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderHierarchy")

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  files     File[]
  isVault   Boolean  @default(false)

  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?

  // Relations pour les partages
  sharedLinks  SharedLink[]
  sharedWith   SharedFolder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, parentId, name]) // Pas deux dossiers du même nom au même endroit
  @@index([userId])
  @@index([parentId])
  @@index([path])
  @@index([isVault])
  @@index([userId, parentId])
  @@index([userId, isDeleted])
}

model AccountSwitchLink {
  id                  String   @id @default(uuid())
  rootUserId          String
  rootUser            User     @relation("SwitchRootUser", fields: [rootUserId], references: [id], onDelete: Cascade)
  targetUserId        String
  targetUser          User     @relation("SwitchTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  label               String?
  expiresAt           DateTime
  lastAuthenticatedAt DateTime
  revokedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([rootUserId, revokedAt, expiresAt])
  @@index([targetUserId])
}

model Delegation {
  id             String           @id @default(uuid())
  ownerUserId    String
  ownerUser      User             @relation("DelegationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  delegateUserId String
  delegateUser   User             @relation("DelegationDelegate", fields: [delegateUserId], references: [id], onDelete: Cascade)
  status         DelegationStatus @default(ACTIVE)
  canRead        Boolean          @default(true)
  canWrite       Boolean          @default(false)
  canDelete      Boolean          @default(false)
  canShare       Boolean          @default(false)
  startsAt       DateTime         @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([ownerUserId, status, revokedAt, expiresAt])
  @@index([delegateUserId, status, revokedAt, expiresAt])
  @@index([ownerUserId, delegateUserId])
}

// --------------------------------------
// 3. FICHIERS
// --------------------------------------

model File {
  id           String   @id @default(uuid())
  name         String
  originalName String
  mimeType     String
  size         BigInt

  storagePath  String   @unique // Lien vers Docker

  // Analytics
  views        Int      @default(0)
  downloads    Int      @default(0)
  lastAccessedAt DateTime @default(now())

  // Nouveau : Pour la prévisualisation & média
  thumbnailPath String? // Lien vers la miniature
  category      String? // 'image', 'video', 'doc', 'audio', 'other' (Pour le graph du Dashboard)

  folderId     String?
  folder       Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sharedLinks  SharedLink[]
  tags         FileTag[]  // Tags associés au fichier
  comments     Comment[]  // Commentaires sur le fichier
  versions     FileVersion[]  // Versions du fichier
  sharedWith   SharedFile[]  // Partages avec d'autres utilisateurs
  isVault      Boolean  @default(false)
  searchIndex  FileSearchIndex?

  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  isFavorite   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([folderId])
  @@index([isDeleted])
  @@index([mimeType])
  @@index([category])
  @@index([isFavorite])
  @@index([isVault])
  @@index([userId, folderId, isDeleted])
  @@index([userId, isDeleted, updatedAt])
  @@index([userId, isDeleted, deletedAt])
  @@index([userId, isDeleted, isFavorite])
}

model FileSearchIndex {
  id           String   @id @default(uuid())
  fileId        String   @unique
  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  extractedText String   @db.Text
  aiSummary     String?  @db.Text
  ocrUsed       Boolean  @default(false)
  indexedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([indexedAt])
}

// --------------------------------------
// 4. PARTAGES & DASHBOARD
// --------------------------------------

model SharedLink {
  id           String    @id @default(uuid())
  token        String    @unique @default(uuid())

  // Peut pointer vers un fichier OU un dossier
  fileId       String?
  file         File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  folderId     String?
  folder       Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // JSON array of file IDs for multi-file bundle links
  bundleFileIds String?
  ownerWrappedDek String? // DEK propriétaire enveloppée pour lire les fichiers partagés

  password     String?
  expiresAt    DateTime?
  downloads    Int       @default(0)
  maxDownloads Int?
  createdAt    DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model SharedFolder {
  id           String   @id @default(uuid())

  folderId     String
  folder       Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  sharedById   String
  sharedBy     User     @relation("SharedByUser", fields: [sharedById], references: [id], onDelete: Cascade)

  sharedWithId String
  sharedWith   User     @relation("SharedWithUser", fields: [sharedWithId], references: [id], onDelete: Cascade)

  // Permissions granulaires
  canRead      Boolean  @default(true)   // Peut consulter les fichiers
  canWrite     Boolean  @default(false)  // Peut uploader/modifier des fichiers
  canDelete    Boolean  @default(false)  // Peut supprimer des fichiers
  canShare     Boolean  @default(false)  // Peut repartager à d'autres utilisateurs

  // Acceptation du partage
  accepted     Boolean  @default(false)  // L'utilisateur a accepté le partage
  ownerWrappedDek String? // DEK propriétaire enveloppée pour les accès au dossier partagé
  createdAt    DateTime @default(now())

  @@unique([folderId, sharedWithId])
  @@index([sharedById])
  @@index([sharedWithId])
}

model SharedFile {
  id           String   @id @default(uuid())

  fileId       String
  file         File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  sharedById   String
  sharedBy     User     @relation("FileSharedByUser", fields: [sharedById], references: [id], onDelete: Cascade)

  sharedWithId String
  sharedWith   User     @relation("FileSharedWithUser", fields: [sharedWithId], references: [id], onDelete: Cascade)

  // Permissions granulaires pour les fichiers
  canRead      Boolean  @default(true)   // Peut consulter/télécharger le fichier
  canWrite     Boolean  @default(false)  // Peut modifier le fichier (upload nouvelle version)
  canDelete    Boolean  @default(false)  // Peut supprimer le fichier
  canShare     Boolean  @default(false)  // Peut repartager à d'autres utilisateurs

  // Acceptation du partage
  accepted     Boolean  @default(false)  // L'utilisateur a accepté le partage
  ownerWrappedDek String? // DEK propriétaire enveloppée pour les accès au fichier partagé
  createdAt    DateTime @default(now())

  @@unique([fileId, sharedWithId])
  @@index([sharedById])
  @@index([sharedWithId])
}

// Nouveau : Pour le Dashboard (Activité récente)
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // 'UPLOAD', 'DELETE', 'LOGIN', 'DOWNLOAD', 'SHARE', 'CREATE_FOLDER'
  details   String?  // JSON avec les détails de l'action
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
}

// --------------------------------------
// 5. SYSTÈME DE TAGS
// --------------------------------------

model Tag {
  id        String    @id @default(uuid())
  name      String
  color     String    @default("#6366f1") // Couleur hexadécimale
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  files     FileTag[]
  createdAt DateTime  @default(now())

  @@unique([userId, name]) // Un utilisateur ne peut pas avoir deux tags avec le même nom
  @@index([userId])
  @@index([name])
}

model FileTag {
  id        String   @id @default(uuid())
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([fileId, tagId]) // Un fichier ne peut pas avoir le même tag deux fois
  @@index([fileId])
  @@index([tagId])
}

// --------------------------------------
// 6. SYSTÈME DE COMMENTAIRES
// --------------------------------------

model Comment {
  id        String   @id @default(uuid())
  content   String

  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Pour les réponses (commentaires imbriqués)
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fileId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

// --------------------------------------
// 7. SYSTÈME DE VERSIONNING
// --------------------------------------

model FileVersion {
  id            String   @id @default(uuid())
  fileId        String
  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  versionNumber Int
  name          String
  size          BigInt
  storagePath   String   @unique
  mimeType      String
  createdAt     DateTime @default(now())
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([fileId, versionNumber])
  @@index([fileId])
  @@index([createdById])
  @@index([createdAt])
}

// --------------------------------------
// 8. SYSTÈME MFA - APPAREILS DE CONFIANCE
// --------------------------------------

model TrustedDevice {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceFingerprint String   // Hash unique de l'appareil (user-agent + IP + accept-language)
  deviceName        String   // Ex: "Chrome on Windows", "Firefox on macOS"
  ipAddress         String

  createdAt         DateTime @default(now())
  expiresAt         DateTime // 30 jours après création
  lastUsedAt        DateTime @default(now())

  @@index([userId])
  @@index([deviceFingerprint])
  @@index([expiresAt])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     OrganizationMember[]
  currentUsers User[]  @relation("CurrentOrganization")

  @@index([name])
}

model OrganizationMember {
  id             String               @id @default(uuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           OrganizationMemberRole @default(MEMBER)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

// --------------------------------------
// 9. NOTIFICATIONS
// --------------------------------------

enum NotificationType {
  SHARE
  COMMENT
  QUOTA
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?            // Metadata (fileId, folderId, etc.)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
}

// --------------------------------------
// 10. PUSH SUBSCRIPTIONS
// --------------------------------------

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// --------------------------------------
// 11. CONVERSATIONS BOBBY (RAG chat)
// --------------------------------------

model Conversation {
  id        String                @id @default(uuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  messages  ConversationMessage[]

  @@index([userId])
  @@index([createdAt])
}

model ConversationMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant"
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}
