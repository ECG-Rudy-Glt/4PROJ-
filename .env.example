# Configuration pour Docker Compose - SUPFILE
# Copiez ce fichier vers .env et modifiez les valeurs selon vos besoins

# ========================================
# CONFIGURATION RÉSEAU
# ========================================
#
# Adresse IP ou nom de domaine de la machine hôte.
# Toutes les URLs (backend, frontend, OnlyOffice, mobile) sont dérivées de cette valeur.
#
# Pour localhost uniquement (par défaut) :
# HOST_IP=localhost
#
# Pour accès réseau local, mettez l'IP de votre machine :
# HOST_IP=192.168.1.100
#
# Pour trouver votre IP :
# - Windows : cmd > ipconfig
# - Mac : terminal > ifconfig | grep "inet "
# - Linux : terminal > ip addr show
HOST_IP=localhost
PUBLIC_BASE_URL=
API_URL=
FRONTEND_URL=
VITE_API_URL=
ONLYOFFICE_PUBLIC_URL=
# Sur VPS avec reverse proxy: BIND_ADDRESS=127.0.0.1:
BIND_ADDRESS=

# ========================================
# PORTS
# ========================================
BACKEND_PORT=5001
FRONTEND_PORT=3000
POSTGRES_PORT=5433
ONLYOFFICE_PORT=8080

# ========================================
# BASE DE DONNÉES
# ========================================
# Superuser PostgreSQL — utilisé uniquement pour l'initialisation du conteneur
# Ne jamais utiliser ce compte dans l'application
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort_ici
POSTGRES_DB=supfile

# Utilisateur applicatif dédié (pas superuser) — utilisé par le backend
# Générer un mot de passe fort : openssl rand -base64 32
POSTGRES_APP_USER=supfile_app
POSTGRES_APP_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort_ici

# ⚠️ IMPORTANT : Ces deux mots de passe DOIVENT être différents et forts en production !
# Ne jamais exposer PostgreSQL sur un port public (voir docker-compose.yml)

# ========================================
# SÉCURITÉ JWT
# ========================================
JWT_SECRET=
JWT_MFA_SECRET=
JWT_EXPIRES_IN=7d
MFA_ENCRYPTION_KEY=
# Clé obligatoire pour chiffrer les secrets MFA (32 bytes hex = 64 caractères)
# Générer avec : openssl rand -hex 32

# Chiffrement par utilisateur (KEK/DEK)
# Générer JWT_SECRET, JWT_MFA_SECRET, DEK_WRAP_SECRET, FILE_ENCRYPTION_KEY et ONLYOFFICE_JWT_SECRET avec : openssl rand -base64 48
DEK_WRAP_SECRET=
FILE_ENCRYPTION_KEY=
ONLYOFFICE_JWT_SECRET=

# ========================================
# EMAIL (SMTP)
# ========================================
# Exemple Brevo : SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@supfile.com
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_MOCK=false
MAIL_LOGO_URL=
 
# ========================================
# OAUTH2 (OPTIONNEL)
# ========================================
# Si vous souhaitez activer l'authentification Google/GitHub,
# créez des applications OAuth2 et ajoutez vos identifiants ici

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========================================
# AI - Bobby le robot (RAG local via Ollama)
# ========================================
# URL interne du microservice RAG (docker-compose interne)
BRAIN_API_URL=http://brain-api:8001
# Modèle Ollama à utiliser (voir : https://ollama.com/library)
OLLAMA_MODEL=gemma2:2b
# Après le premier `docker compose up`, lance une fois :
#   ./scripts/pull_model.sh

# ========================================
# OBJECT STORAGE — MINIO
# ========================================
MINIO_ROOT_USER=supfile_minio
MINIO_ROOT_PASSWORD=
# Compte applicatif MinIO (accès limité au bucket, distinct du root)
MINIO_APP_ACCESS_KEY=supfile_app_key
MINIO_APP_SECRET_KEY=
S3_BUCKET=supfile-uploads
S3_REGION=us-east-1

# ========================================
# WEB PUSH (VAPID)
# ========================================
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ========================================
# STRIPE BILLING
# ========================================
# Mode test pour la preproduction ecole: sk_test_..., whsec_..., price_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# ========================================
# INSTRUCTIONS RAPIDES
# ========================================
#
# 1. Localhost (par défaut) : HOST_IP=localhost → docker compose up -d --build
# 2. Réseau local           : HOST_IP=192.168.1.100 → docker compose up -d --build
# 3. Mobile                 : mettre la même IP dans mobile/.env → EXPO_PUBLIC_API_URL=http://HOST_IP:5001
