# Configuration pour Docker Compose - SUPFILE
# Copiez ce fichier vers .env et modifiez les valeurs selon vos besoins

# ========================================
# CONFIGURATION RÉSEAU
# ========================================
#
# Pour localhost uniquement (par défaut) :
# HOST_IP=localhost
#
# Pour accès réseau local, utilisez l'IP de votre machine :
# Exemple : HOST_IP=192.168.1.100
#
# Pour trouver votre IP :
# - Windows : cmd > ipconfig
# - Mac : terminal > ifconfig | grep "inet "
# - Linux : terminal > ip addr show
#
HOST_IP=localhost

# URLs du backend et frontend
# Ces URLs seront utilisées par les containers Docker
# Pour localhost : http://localhost:5001 et http://localhost:3000
# Pour réseau local : http://VOTRE_IP:5001 et http://VOTRE_IP:3000
API_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3000

# ========================================
# PORTS
# ========================================
BACKEND_PORT=5001
FRONTEND_PORT=3000
POSTGRES_PORT=5432

# ========================================
# BASE DE DONNÉES
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=supfile

# ⚠️ IMPORTANT : Changez ces valeurs en production !

# ========================================
# SÉCURITÉ JWT
# ========================================
JWT_SECRET=super-secret-jwt-key-change-in-production-12345
JWT_EXPIRES_IN=7d

# ⚠️ IMPORTANT : Générez un nouveau secret JWT pour la production !
# Vous pouvez générer un secret avec : openssl rand -base64 32

# ========================================
# OAUTH2 (OPTIONNEL)
# ========================================
# Si vous souhaitez activer l'authentification Google/GitHub,
# créez des applications OAuth2 et ajoutez vos identifiants ici

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========================================
# AI - Bobby le robot (RAG local via Ollama)
# ========================================
# URL interne du microservice RAG (docker-compose interne)
BRAIN_API_URL=http://brain-api:8001
# Modèle Ollama à utiliser (voir : https://ollama.com/library)
OLLAMA_MODEL=qwen2.5:0.5b
# Après le premier `docker compose up`, lance une fois :
#   ./brain-api/pull_model.sh

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# ========================================
# INSTRUCTIONS RAPIDES
# ========================================
#
# 1. Configuration pour localhost (par défaut) :
#    - Laissez HOST_IP=localhost
#    - Démarrez avec : docker compose up -d --build
#    - Accédez à : http://localhost:3000
#
# 2. Configuration pour réseau local :
#    - Trouvez votre IP avec les commandes ci-dessus
#    - Modifiez HOST_IP=VOTRE_IP
#    - Modifiez API_URL=http://VOTRE_IP:5001
#    - Modifiez FRONTEND_URL=http://VOTRE_IP:3000
#    - Configurez le pare-feu (ports 3000 et 5001)
#    - Démarrez avec : docker compose up -d --build
#    - Accédez depuis n'importe quel PC du réseau : http://VOTRE_IP:3000
#
# 3. Utilisation des scripts automatiques :
#    - Linux/Mac : ./configure-network.sh
#    - Windows : .\configure-network.ps1 (PowerShell en admin)
#
# Pour plus de détails, consultez CONFIGURATION_RESEAU.md
