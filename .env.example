# Configuration pour Docker Compose - SUPFILE
# Copiez ce fichier vers .env et modifiez les valeurs selon vos besoins

# ========================================
# CONFIGURATION RESEAU
# ========================================
# Ces variables sont GEREES AUTOMATIQUEMENT par les scripts :
#   - make dev        (hot-start.ps1 / hot-start.sh)
#   - make mobile     (start-mobile.ps1 / start-mobile.sh)
#
# Les scripts detectent l'IP locale et mettent a jour ces valeurs.
# Vous n'avez PAS besoin de les modifier manuellement.
#
# HOST_IP        -> IP detectee automatiquement
# API_URL        -> http://{HOST_IP}:5001
# FRONTEND_URL   -> http://{HOST_IP}:3000
# VITE_API_URL   -> http://{HOST_IP}:5001
# ONLYOFFICE_PUBLIC_URL -> http://{HOST_IP}:8080
#
# Valeur par defaut (utilisee si script non execute) :
HOST_IP=localhost

# Sur VPS avec reverse proxy, decommentez :
# BIND_ADDRESS=127.0.0.1:

# ========================================
# PORTS
# ========================================
BACKEND_PORT=5001
FRONTEND_PORT=3000
POSTGRES_PORT=5433
ONLYOFFICE_PORT=8080

# ========================================
# BASE DE DONNEES (OBLIGATOIRE)
# ========================================
# Superuser PostgreSQL - utilise uniquement pour l'initialisation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort_ici
POSTGRES_DB=supfile

# Utilisateur applicatif dedie (pas superuser) - utilise par le backend
# Generer un mot de passe fort : openssl rand -base64 32
POSTGRES_APP_USER=supfile_app
POSTGRES_APP_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort_ici

# ========================================
# SECURITE JWT (OBLIGATOIRE)
# ========================================
# Generer avec : openssl rand -base64 48
JWT_SECRET=
JWT_MFA_SECRET=
JWT_EXPIRES_IN=7d

# Cle pour chiffrer les secrets MFA (32 bytes hex = 64 caracteres)
# Generer avec : openssl rand -hex 32
MFA_ENCRYPTION_KEY=

# Chiffrement par utilisateur (KEK/DEK)
# Generer avec : openssl rand -base64 48
DEK_WRAP_SECRET=
FILE_ENCRYPTION_KEY=
ONLYOFFICE_JWT_SECRET=

# ========================================
# EMAIL SMTP (OBLIGATOIRE)
# ========================================
# Exemple Brevo : SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@supfile.com
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_MOCK=false
MAIL_LOGO_URL=

# ========================================
# OBJECT STORAGE MINIO (OBLIGATOIRE)
# ========================================
MINIO_ROOT_USER=supfile_minio
# Generer avec : openssl rand -base64 48
MINIO_ROOT_PASSWORD=

# Compte applicatif MinIO (acces limite au bucket)
MINIO_APP_ACCESS_KEY=supfile_app_key
# Generer avec : openssl rand -base64 48
MINIO_APP_SECRET_KEY=

S3_BUCKET=supfile-uploads
S3_REGION=us-east-1

# ========================================
# WEB PUSH VAPID (OBLIGATOIRE)
# ========================================
# Generer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ========================================
# STRIPE BILLING (OPTIONNEL)
# ========================================
# Mode test : sk_test_..., whsec_..., price_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# ========================================
# OAUTH2 (OPTIONNEL)
# ========================================
# Authentification Google/GitHub
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========================================
# IA - Bobby le robot (OPTIONNEL)
# ========================================
# URL interne du microservice RAG
BRAIN_API_URL=http://brain-api:8001
# Modele Ollama (voir : https://ollama.com/library)
OLLAMA_MODEL=gemma2:2b

# ========================================
# DEMARRAGE RAPIDE
# ========================================
#
# 1. Copier ce fichier :
#    cp .env.example .env
#
# 2. Generer les secrets obligatoires :
#    openssl rand -base64 48  # pour JWT_SECRET, etc.
#    openssl rand -hex 32     # pour MFA_ENCRYPTION_KEY
#    npx web-push generate-vapid-keys
#
# 3. Lancer en mode dev (IP auto-detectee) :
#    make dev
#
# 4. Lancer le mobile :
#    make mobile
